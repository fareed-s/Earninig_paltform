# ===================================
# EARNING PLATFORM - ENV TEMPLATE
# Copy this file to .env and fill values
# cp .env.example .env
# ===================================

# ---- MongoDB ----
MONGO_USER=admin
MONGO_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# ---- JWT ----
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_KEY_64_CHARS
JWT_EXPIRE=7d

# ---- Admin Seed ----
ADMIN_EMAIL=admin@yourplatform.com
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
ADMIN_NAME=Admin

# ---- App Port ----
APP_PORT=80
